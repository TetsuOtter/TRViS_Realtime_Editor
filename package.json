{
	"name": "trvis-realtime-editor",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@11.0.8",
	"scripts": {
		"dev": "vite",
		"build": "pnpm licenses:generate && tsc -b && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"icons:render": "node scripts/render-app-icon.mjs",
		"icons": "pnpm icons:render && tauri icon src-tauri/icons/app-icon.png",
		"licenses:generate": "node scripts/generate-third-party-licenses.mjs",
		"postinstall": "node -e \"const fs=require('fs');if(!fs.existsSync('src-tauri/icons/icon.png')){const r=require('child_process').spawnSync('pnpm icons',{stdio:'inherit',shell:true});if(r.status!==0)process.exit(r.status||1)}\"",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fmt:rust": "cargo fmt --all",
		"fmt:rust:check": "cargo fmt --all -- --check",
		"fmt:all": "pnpm format && pnpm fmt:rust",
		"check": "pnpm lint && pnpm format:check && pnpm fmt:rust:check",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:ui": "playwright test",
		"test:e2e:ui:headed": "playwright test --headed",
		"harness:up": "docker compose -f docker/docker-compose.yml up --build",
		"harness:down": "docker compose -f docker/docker-compose.yml down -v"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lint": "6.9.5",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "6.41.1",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@types/json-schema": "^7.0.15",
		"codemirror": "^6.0.2",
		"codemirror-json-schema": "^0.8.1",
		"immer": "11.1.4",
		"json-schema-library": "^11.4.0",
		"jsonc-parser": "^3.3.1",
		"maplibre-gl": "^5.24.0",
		"qrcode": "^1.5.4",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-error-boundary": "^6.1.1",
		"uuid": "^14.0.0",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.59.1",
		"@resvg/resvg-js": "^2.6.2",
		"@tauri-apps/cli": "2.11.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "25.6.0",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^11.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^15.15.0",
		"happy-dom": "^20.9.0",
		"prettier": "^3.8.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.59.1",
		"vite": "8.0.10",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"overrides": {
			"@codemirror/view": "6.41.1",
			"@codemirror/lint": "6.9.5",
			"zustand": "5.0.12",
			"@tauri-apps/cli": "2.11.0",
			"immer": "11.1.4",
			"vite": "8.0.10"
		}
	}
}
