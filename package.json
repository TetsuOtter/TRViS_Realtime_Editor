{
	"name": "trvis-realtime-editor",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@11.0.8",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fmt:rust": "cargo fmt --all",
		"fmt:rust:check": "cargo fmt --all -- --check",
		"fmt:all": "pnpm format && pnpm fmt:rust",
		"check": "pnpm lint && pnpm format:check && pnpm fmt:rust:check",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"harness:up": "docker compose -f docker/docker-compose.yml up --build",
		"harness:down": "docker compose -f docker/docker-compose.yml down -v"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.1.1",
		"@tauri-apps/plugin-shell": "^2.0.1",
		"immer": "^10.1.1",
		"maplibre-gl": "^4.7.1",
		"qrcode": "^1.5.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-error-boundary": "^4.1.2",
		"uuid": "^11.0.3",
		"zustand": "^5.0.2"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2.1.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.0",
		"@types/qrcode": "^1.5.5",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/uuid": "^10.0.0",
		"@eslint/js": "^9.17.0",
		"@vitejs/plugin-react": "^4.3.4",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-react": "^7.37.2",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.16",
		"globals": "^15.14.0",
		"typescript-eslint": "^8.18.0",
		"happy-dom": "^15.11.7",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vitest": "^2.1.8"
	}
}
