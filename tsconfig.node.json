{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"composite": true,
		"declaration": true,
		"declarationDir": ".ts-cache",
		"emitDeclarationOnly": true,
		"resolveJsonModule": true
	},
	"include": ["vite.config.ts", "vitest.e2e.config.ts"]
}
